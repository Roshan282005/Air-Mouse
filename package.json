{
  "name": "air-mouse-mvp",
  "version": "0.1.0",
  "description": "Hands-free Air-Mouse with gaze, gesture, and voice control",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "py:setup": "python -m venv venv && source venv/bin/activate && pip install -r ml/requirements.txt",
    "py:export-models": "python ml/scripts/export_models.py",
    "py:train": "python ml/scripts/train_gesture_model.py"
  },
  "keywords": ["air-mouse", "gaze-tracking", "gesture-recognition", "voice-control", "accessibility"],
  "author": "Air-Mouse Team",
  "license": "MIT",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.0",
    "framer-motion": "^10.16.0"
  },
  "devDependencies": {
    "typescript": "^5.2.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/node": "^20.4.0",
    "vite": "^4.4.0",
    "@vitejs/plugin-react": "^4.0.0",
    "eslint": "^8.45.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "vitest": "^0.34.0",
    "tailwindcss": "^3.3.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0"
  }
}
